# Copy this file to .env and edit values as needed.

# App settings (backend/app/core/config.py)
APP_NAME=AI Exam Prep API
APP_VERSION=1.1.0
UPLOAD_DIR=uploads

# Use JSON array syntax for multiple origins.
ALLOW_ORIGINS=["*"]

# Planned AI/data integrations (for next phase)
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
EMBED_MODEL=text-embedding-3-small
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assitify_ai
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
REDIS_URL=redis://localhost:6379/0
